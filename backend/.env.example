# ──────────────────────────────────────────────────────────────────────────────
# GoHighLevel (GHL) API credentials
# ──────────────────────────────────────────────────────────────────────────────
# 1. Log into your GHL account
# 2. Go to: Settings → Integrations → Private Integrations → Create new
# 3. Grant scopes: contacts.write, invoices.write, invoices.readonly
# 4. Copy the token below:
GHL_API_KEY=your_private_integration_token_here

# 5. Go to: Settings → Business Profile → scroll to "Location ID"
# 6. Copy the ID below:
GHL_LOCATION_ID=your_location_id_here

# ──────────────────────────────────────────────────────────────────────────────
# Email (contact & fleet forms) — supports both Resend and SMTP
# ──────────────────────────────────────────────────────────────────────────────
# Option 1: Resend (free, resend.com)
# 1. Sign up at resend.com (free — 3,000 emails/month)
# 2. Go to API Keys → Create API Key
# 3. Paste it below:
RESEND_API_KEY=re_your_api_key_here

# Option 2: SMTP (e.g. Gmail)
# For Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
CONTACT_EMAIL=calebelliott933@gmail.com

# ──────────────────────────────────────────────────────────────────────────────
# Database (if used)
# ──────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
